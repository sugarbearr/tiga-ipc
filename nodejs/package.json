{
  "name": "@tiga-ipc/mmap",
  "version": "0.3.2",
  "description": "Windows memory-mapped IPC bindings for Tiga channels.",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "index.js",
    "index.d.ts",
    "index.node",
    "runtime/"
  ],
  "os": [
    "win32"
  ],
  "scripts": {
    "test": "cargo test && node --test ./runtime/server.test.js",
    "cargo-build": "node ./scripts/build-addon.js",
    "cross-build": "node ./scripts/build-addon.js",
    "debug": "npm run cargo-build --",
    "build": "npm run cargo-build -- --release",
    "cross": "npm run cross-build -- --release",
    "sync:types": "node ./scripts/sync-package-types.js",
    "publish:check": "npm publish --dry-run --access public",
    "prepack": "node -e \"require('fs').accessSync('index.node')\" && npm run sync:types"
  },
  "keywords": [
    "ipc",
    "mmap",
    "memory-mapped-file",
    "napi-rs",
    "tiga"
  ],
  "author": "TigaIpc contributors",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sugarbearr/tiga-ipc.git",
    "directory": "nodejs/mmap-napi"
  },
  "bugs": {
    "url": "https://github.com/sugarbearr/tiga-ipc/issues"
  },
  "homepage": "https://github.com/sugarbearr/tiga-ipc",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  }
}
